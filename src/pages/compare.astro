---
import BaseLayout from '../layouts/BaseLayout.astro';
import InteractiveCompare from '../components/compare/InteractiveCompare';
---

<BaseLayout 
  title="チップ比較ツール | Apple Silicon スペック横並び比較"
  description="Apple Mシリーズ・Aシリーズチップを最大3つまで選択し、スペックやベンチマークを視覚的に比較できるインタラクティブツール。"
>
  <section class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 mb-20">
    <div class="mb-16">
      <h1 class="text-5xl font-bold tracking-tight mb-4">Interactive Compare</h1>
      <p class="text-xl text-text-sub max-w-2xl">
        気になるチップを選んで、スペックと性能を直接比較。
        最大3つのプロセッサを並べて、その進化の差を確かめましょう。
      </p>
    </div>

    <!-- React Island for Interactive Comparison -->
    <InteractiveCompare client:visible />
  </section>
</BaseLayout>
